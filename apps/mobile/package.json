{
  "name": "@rabbit-hole/mobile",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "test": "jest"
  },
  "dependencies": {
    "@rabbit-hole/contracts": "*",
    "expo": "~52.0.40",
    "react": "18.3.1",
    "react-native": "0.76.7"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "^29.5.14",
    "@types/react": "~18.3.12",
    "@types/react-native": "~0.73.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "typescript": "^5.8.2"
  },
  "jest": {
    "preset": "react-native",
    "testMatch": ["**/__tests__/**/*.test.ts", "**/__tests__/**/*.test.tsx"],
    "moduleNameMapper": {
      "^@rabbit-hole/contracts$": "<rootDir>/../../packages/contracts/src/index.ts"
    },
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|expo|@expo|@unimodules|@react-navigation)/)"
    ]
  }
}
